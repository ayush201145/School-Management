# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/school_mgmt?schema=public"

# JWT
JWT_SECRET="change-this-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# CORS - comma separated list of allowed origins (your Android app doesn't need this,
# but useful if you ever add a web admin panel)
CORS_ORIGIN="*"
